<?xml version="1.0"?>
<object name="portal_actions" meta_type="Plone Actions Tool">
  <object name="object" meta_type="CMF Action Category">
    <object name="custom_interfaces"
            meta_type="CMF Action"
            xmlns:i18n="http://xml.zope.org/namespaces/i18n"
            i18n:domain="{{package_name}}">
      <property name="title">Interfacce</property>
      <property name="description"></property>
      <property name="url_expr">string:${object_url}/@@interfaces</property>
      <property name="icon_expr">string:file-image</property>
      <property name="available_expr">python:checkPermission('Manage portal', object)</property>
      <property name="permissions">
        <element value="Manage portal"/>
      </property>
      <property name="visible">True</property>
    </object>
  </object>
</object>
